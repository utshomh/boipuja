{
  "name": "boipuja",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "bun --env-file=.env.development --watch apps/api/src/index.ts",
    "db:generate": "bun --cwd packages/db --env-file=../../.env.development drizzle-kit generate",
    "db:migrate": "bun --cwd packages/db --env-file=../../.env.development drizzle-kit migrate",
    "db:studio": "bun --cwd packages/db --env-file=../../.env.development drizzle-kit studio",
    "db:reset:test": "bun --cwd packages/db --env-file=../../.env.test scripts/reset-test-db.ts",
    "db:migrate:test": "bun --cwd packages/db --env-file=../../.env.test drizzle-kit migrate",
    "db:studio:test": "bun --cwd packages/db --env-file=../../.env.test drizzle-kit studio",
    "test:api": "bun test --env-file=.env.test apps/api/src/**/*.test.ts",
    "test:api:fresh": "bun run db:reset:test && bun run db:migrate:test && bun run test:api",
    "typecheck": "bunx tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "latest"
  },
  "packageManager": "pnpm@10.10.0+sha512.d615db246fe70f25dcfea6d8d73dee782ce23e2245e3c4f6f888249fb568149318637dca73c2c5c8ef2a4ca0d5657fb9567188bfab47f566d1ee6ce987815c39"
}
