{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "types": [
      "bun-types"
    ],
    "paths": {
      "@boipuja/db": [
        "./packages/db/src/index.ts"
      ],
      "@boipuja/db/*": [
        "./packages/db/src/*"
      ],
      "@boipuja/contracts": [
        "./packages/contracts/src/index.ts"
      ],
      "@boipuja/contracts/*": [
        "./packages/contracts/src/*"
      ]
    }
  }
}